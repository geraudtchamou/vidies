{
  "name": "videotools",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "yarn workspace @videotools/web dev",
    "dev:mobile": "yarn workspace @videotools/mobile start",
    "build:core": "yarn workspace @videotools/core build",
    "build:web": "yarn workspace @videotools/web build",
    "build:mobile": "yarn workspace @videotools/mobile build",
    "build": "yarn workspaces run build",
    "lint": "yarn workspaces run lint"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@1.22.21"
}
